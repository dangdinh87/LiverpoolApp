<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Liverpool FC — Standings</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #0D0D0D; --surface: #1A1A1A; --surface2: #252525;
    --red: #C8102E; --red-dark: #A00E24; --red-glow: rgba(200,16,46,0.25);
    --gold: #F6EB61; --white: #fff; --muted: #A0A0A0; --border: #2A2A2A;
  }
  body { background: var(--black); color: var(--white); font-family: 'Inter', sans-serif; }

  /* NAV */
  nav { position: fixed; top: 0; width: 100%; z-index: 100; background: rgba(26,26,26,0.96); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 64px; }
  .nav-logo { display: flex; align-items: center; gap: 10px; }
  .nav-logo svg { width: 36px; height: 36px; }
  .nav-logo span { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 0.1em; }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a { font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .nav-links a.active { color: var(--white); border-bottom: 2px solid var(--red); padding-bottom: 2px; }
  .nav-cta { background: var(--red); color: var(--white); font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 8px 20px; border: none; cursor: pointer; }

  /* PAGE HEADER */
  .page-header { padding: 100px 2rem 2rem; max-width: 1280px; margin: 0 auto; }
  .breadcrumb { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; }
  .breadcrumb span { color: var(--red); }
  .page-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 6vw, 5rem); letter-spacing: 0.02em; }

  /* LEAGUE SELECTOR */
  .league-selector { max-width: 1280px; margin: 0 auto; padding: 1.5rem 2rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .league-btn { display: flex; align-items: center; gap: 8px; background: var(--surface); border: 1px solid var(--border); padding: 10px 18px; cursor: pointer; transition: all 0.15s; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .league-btn:hover { color: var(--white); border-color: var(--surface2); }
  .league-btn.active { background: var(--surface2); border-color: var(--red); color: var(--white); }
  .league-dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-pl { background: #6C63FF; }
  .dot-ucl { background: #3B82F6; }

  /* TABLE WRAPPER */
  .table-wrapper { max-width: 1280px; margin: 0 auto; padding: 0 2rem 5rem; display: grid; grid-template-columns: 1fr 300px; gap: 2rem; align-items: start; }

  /* TABLE CARD */
  .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }
  .table-header { display: grid; grid-template-columns: 40px 1fr repeat(7, 48px) 100px 32px; gap: 0; padding: 10px 16px; border-bottom: 1px solid var(--border); background: var(--surface2); }
  .th { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-align: center; }
  .th:nth-child(2) { text-align: left; }

  /* Table Row */
  .table-row { display: grid; grid-template-columns: 40px 1fr repeat(7, 48px) 100px 32px; gap: 0; padding: 10px 16px; border-bottom: 1px solid rgba(42,42,42,0.6); align-items: center; transition: background 0.15s; cursor: pointer; }
  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: rgba(255,255,255,0.02); }
  .table-row.lfc-row { background: rgba(200,16,46,0.07); border-left: 3px solid var(--red); }
  .table-row.lfc-row:hover { background: rgba(200,16,46,0.1); }
  .table-row.champions { border-left: 3px solid #6C63FF; }
  .table-row.ucl { border-left: 3px solid #3B82F6; }
  .table-row.rel { border-left: 3px solid #ef4444; }

  .td { font-family: 'Inter', sans-serif; font-size: 0.85rem; text-align: center; color: var(--white); }
  .td.left { text-align: left; }
  .td.muted { color: var(--muted); }
  .td.bold { font-weight: 700; }

  /* Position number */
  .pos-num { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; line-height: 1; text-align: center; }
  .pos-num.top { color: var(--red); }
  .pos-champion { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: #6C63FF; }

  /* Team cell */
  .team-cell { display: flex; align-items: center; gap: 10px; }
  .team-crest { width: 24px; height: 24px; border-radius: 50%; background: var(--surface2); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 0.55rem; color: var(--muted); flex-shrink: 0; }
  .team-crest.lfc { border-color: var(--red); color: var(--red); background: rgba(200,16,46,0.1); }
  .team-label { font-size: 0.9rem; font-weight: 500; }
  .team-label.lfc { color: var(--red); font-weight: 700; }

  /* Progress bar */
  .pts-bar-wrap { display: flex; align-items: center; gap: 6px; }
  .pts-bar { flex: 1; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .pts-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
  .pts-fill.lfc { background: var(--red); }
  .pts-fill.top { background: #6C63FF; }
  .pts-fill.mid { background: var(--muted); opacity: 0.4; }
  .pts-fill.low { background: #ef4444; opacity: 0.4; }

  /* PTS number in bar col */
  .pts-num { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; text-align: right; min-width: 28px; }
  .pts-num.lfc { color: var(--red); }

  /* Form mini dots */
  .mini-form { display: flex; gap: 3px; justify-content: flex-end; }
  .mf-dot { width: 14px; height: 14px; border-radius: 50%; font-family: 'Bebas Neue', sans-serif; font-size: 0.55rem; display: flex; align-items: center; justify-content: center; }
  .mf-dot.W { background: rgba(34,197,94,0.3); color: #22c55e; }
  .mf-dot.D { background: rgba(234,179,8,0.25); color: #eab308; }
  .mf-dot.L { background: rgba(239,68,68,0.2); color: #ef4444; }

  /* Qualification legend */
  .legend { display: flex; flex-wrap: wrap; gap: 1rem; padding: 1rem 16px; border-top: 1px solid var(--border); background: rgba(0,0,0,0.2); }
  .legend-item { display: flex; align-items: center; gap: 6px; font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .legend-bar { width: 12px; height: 3px; border-radius: 1px; }

  /* SIDEBAR */
  .sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .sidebar-card { background: var(--surface); border: 1px solid var(--border); border-radius: 2px; padding: 1.25rem; }
  .sidebar-title { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 1rem; }
  .lfc-hero-stat { text-align: center; margin-bottom: 1rem; }
  .lfc-hero-stat .n { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; line-height: 1; color: var(--red); }
  .lfc-hero-stat .l { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }
  .stat-grid-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .sgm-item { background: var(--surface2); border: 1px solid var(--border); padding: 0.75rem; text-align: center; }
  .sgm-val { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; line-height: 1; }
  .sgm-lbl { font-family: 'Barlow Condensed', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-top: 2px; }
  .title-chances { margin-top: 1rem; }
  .chances-label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
  .chances-bar { height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
  .chances-fill { height: 100%; background: linear-gradient(to right, var(--red), #FF4060); border-radius: 4px; width: 84%; }
  .chances-pct { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: var(--red); margin-top: 4px; }

  .top-scorer-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); }
  .top-scorer-row:last-child { border-bottom: none; }
  .scorer-name { font-size: 0.85rem; }
  .scorer-team { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .scorer-goals { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; }

  @media (max-width: 1024px) { .table-wrapper { grid-template-columns: 1fr; } .sidebar { display: none; } }
</style>
</head>
