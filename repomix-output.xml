          >
            You'll Never Walk Alone
          </motion.p>

          {/* Red progress bar */}
          <motion.div
            className="w-48 h-0.5 bg-stadium-surface2 overflow-hidden mt-2"
          >
            <motion.div
              className="h-full bg-lfc-red"
              initial={{ scaleX: 0, originX: 0 }}
              animate={{ scaleX: 1 }}
