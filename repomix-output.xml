        >
          <div className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
            {/* Header area */}
            <div className={content.heroImage ? "-mt-40 relative z-10" : "pt-28"}>
              <Link
                href="/news"
