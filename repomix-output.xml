                    <p className="font-inter text-stadium-muted text-[11px] leading-relaxed mt-0.5">{t(`glossary.items.${item.i18nKey}.desc`)}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
