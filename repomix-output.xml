        (f.teams.home.id === 40 || f.teams.away.id === 40)
    );

    return NextResponse.json(
      { fixture: live ?? null },
      {
        headers: {
          "Cache-Control": "public, s-maxage=30, stale-while-revalidate=30",
        },
      }
    );
  } catch {
    return NextResponse.json({ fixture: null }, { status: 500 });
  }
}
