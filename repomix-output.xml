}

/* ─── Dark Mode (default) ─────────────────────────────────────── */
:root {
  --radius: 0.625rem;

  /* Dark Stadium palette as shadcn tokens */
  --background: #0d0d0d;
  --foreground: #f5f5f5;
  --card: #1a1a1a;
  --card-foreground: #f5f5f5;
  --popover: #1a1a1a;
