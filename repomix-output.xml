const ADJECTIVES = [
  'Focused',
  'Deep',
  'Creative',
  'Strategic',
  'Productive',
  'Mindful',
  'Efficient',
  'Dynamic',
  'Structured',
  'Inspired',
  'Clear',
  'Intentional',
  'Active',
  'Brilliant',
  'Smart',
];

const NOUNS = [
  'Session',
  'Sprint',
  'Flow',
