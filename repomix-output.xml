@import 'tailwindcss';
@import 'tw-animate-css';
@import 'shadcn/tailwind.css';

@custom-variant dark (&:is(.dark *));

/* ─── Dark Stadium Design Tokens ─────────────────────────────── */
@theme inline {
  /* shadcn/ui system colors → Dark Stadium overrides */
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-inter);
  --font-mono: var(--font-bebas);

  /* Liverpool color tokens (available as Tailwind classes) */
  --color-lfc-red: #c8102e;
  --color-lfc-red-dark: #a00e24;
  --color-lfc-gold: #f6eb61;
  --color-stadium-bg: #0d0d0d;
