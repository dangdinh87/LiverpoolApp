export async function getNewsPaginated(
  offset: number,
  limit: number,
  language?: "en" | "vi"
): Promise<{ articles: NewsArticle[]; hasMore: boolean }> {
  const supabase = getServiceClient();

  let query = supabase
    .from("articles")
    .select(ARTICLE_COLUMNS)
    .eq("is_active", true)
    .order("published_at", { ascending: false })
    .range(offset, offset + limit);

