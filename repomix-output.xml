<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Liverpool FC — Squad</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #0D0D0D; --surface: #1A1A1A; --surface2: #252525;
    --red: #C8102E; --red-dark: #A00E24; --red-glow: rgba(200,16,46,0.25);
    --gold: #F6EB61; --white: #fff; --muted: #A0A0A0; --border: #2A2A2A;
  }
  body { background: var(--black); color: var(--white); font-family: 'Inter', sans-serif; overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    background: rgba(26,26,26,0.96); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 64px;
  }
  .nav-logo { display: flex; align-items: center; gap: 10px; }
  .nav-logo svg { width: 36px; height: 36px; }
  .nav-logo span { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 0.1em; }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a { font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; padding-bottom: 2px; }
  .nav-links a.active { color: var(--white); border-bottom: 2px solid var(--red); }
  .nav-cta { background: var(--red); color: var(--white); font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 8px 20px; border: none; cursor: pointer; }

  /* PAGE HERO */
  .page-hero {
    padding: 120px 2rem 3rem; position: relative;
    background: linear-gradient(180deg, rgba(200,16,46,0.06) 0%, transparent 100%);
    border-bottom: 1px solid var(--border);
  }
  .page-hero::before {
    content: 'SQUAD'; position: absolute; right: 2rem; top: 80px;
    font-family: 'Bebas Neue', sans-serif; font-size: 10rem; color: rgba(255,255,255,0.03); line-height: 1; pointer-events: none;
  }
  .breadcrumb { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; }
  .breadcrumb span { color: var(--red); }
  .page-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 6vw, 5rem); letter-spacing: 0.02em; }
  .page-subtitle { font-size: 1rem; color: var(--muted); margin-top: 0.5rem; }
  .hero-meta { display: flex; gap: 2rem; margin-top: 1.5rem; }
  .meta-item { font-family: 'Barlow Condensed', sans-serif; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .meta-item strong { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--white); display: block; line-height: 1; }
  .meta-item span { color: var(--muted); }

  /* FILTERS */
  .filters { max-width: 1280px; margin: 0 auto; padding: 2rem 2rem 0; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  .filter-tabs { display: flex; gap: 6px; }
  .tab { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 8px 18px; background: var(--surface); border: 1px solid var(--border); color: var(--muted); cursor: pointer; transition: all 0.15s; }
  .tab:hover { color: var(--white); border-color: var(--surface2); }
  .tab.active { background: var(--red); border-color: var(--red); color: var(--white); }
  .filter-right { display: flex; align-items: center; gap: 1rem; }
  .search-box { background: var(--surface); border: 1px solid var(--border); color: var(--white); font-family: 'Inter', sans-serif; font-size: 0.85rem; padding: 8px 14px; width: 200px; outline: none; }
  .search-box::placeholder { color: var(--muted); }
  .search-box:focus { border-color: var(--red); }
  .sort-select { background: var(--surface); border: 1px solid var(--border); color: var(--muted); font-family: 'Barlow Condensed', sans-serif; font-size: 0.8rem; letter-spacing: 0.08em; padding: 8px 14px; cursor: pointer; outline: none; }

  /* SECTION HEADER */
  .position-section { max-width: 1280px; margin: 0 auto; padding: 2.5rem 2rem 0; }
  .pos-label { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .pos-label h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.04em; }
  .pos-label .count { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); background: var(--surface); border: 1px solid var(--border); padding: 3px 10px; }
  .pos-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* PLAYER GRID */
  .player-grid { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }

  /* PLAYER CARD */
  .player-card {
    background: var(--surface); border: 1px solid var(--border);
    position: relative; overflow: hidden; cursor: pointer;
    transition: border-color 0.25s, box-shadow 0.25s;
    border-radius: 2px;
  }
  .player-card:hover { border-color: var(--red); box-shadow: 0 0 28px var(--red-glow); }
  .player-card:hover .card-actions { opacity: 1; transform: translateY(0); }

  /* Jersey number watermark */
  .jersey-wm { position: absolute; right: -8px; bottom: -8px; font-family: 'Bebas Neue', sans-serif; font-size: 7rem; line-height: 1; color: rgba(255,255,255,0.04); pointer-events: none; user-select: none; }

  /* Player image placeholder */
  .player-img-wrap { width: 100%; aspect-ratio: 3/4; position: relative; background: linear-gradient(to bottom, #252525 0%, #1a1a1a 100%); overflow: hidden; display: flex; align-items: flex-end; justify-content: center; }
  .player-silhouette { width: 70%; aspect-ratio: 1/1.6; background: linear-gradient(to bottom, rgba(200,16,46,0.08) 0%, rgba(200,16,46,0.04) 100%); border-radius: 50% 50% 0 0 / 40% 40% 0 0; margin-bottom: 0; }
  .player-number-badge { position: absolute; top: 10px; left: 10px; font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; background: var(--red); color: var(--white); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; }
  .nationality-flag { position: absolute; top: 10px; right: 10px; font-size: 1.2rem; }

  /* Card info */
  .card-info { padding: 1rem 1rem 1.25rem; position: relative; z-index: 1; }
  .player-position { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); }
  .player-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 0.03em; line-height: 1.1; margin-top: 2px; }
  .player-stats { display: flex; gap: 1rem; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .ps-item { display: flex; flex-direction: column; }
  .ps-val { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; line-height: 1; color: var(--white); }
  .ps-lbl { font-family: 'Barlow Condensed', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

  /* Hover actions */
  .card-actions { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(200,16,46,0.85), transparent); padding: 2rem 1rem 1rem; opacity: 0; transform: translateY(4px); transition: all 0.25s; display: flex; gap: 8px; }
  .card-btn { flex: 1; background: var(--red); color: var(--white); font-family: 'Barlow Condensed', sans-serif; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 8px; border: none; cursor: pointer; }
  .card-btn.ghost { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); }

  /* Captain badge */
  .captain-badge { position: absolute; bottom: 10px; right: 10px; background: var(--gold); color: #0D0D0D; font-family: 'Bebas Neue', sans-serif; font-size: 0.7rem; padding: 2px 6px; letter-spacing: 0.05em; z-index: 5; }

  /* Injury badge */
  .injury-badge { position: absolute; top: 52px; left: 10px; background: rgba(239,68,68,0.9); color: white; font-family: 'Barlow Condensed', sans-serif; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 8px; z-index: 5; }

  @media (max-width: 1024px) { .player-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) { .player-grid { grid-template-columns: repeat(2, 1fr); } .page-hero::before { display: none; } }
</style>
</head>
